  CLASSES = c(5);
  AUXILIARY =
    owd(DU3STEP) dch(DU3STEP) q42p(DU3STEP) rpol2(DU3STEP) supw(DU3STEP) spol(DU3STEP);
  MISSING = ALL(-999);
